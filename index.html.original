<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>NGUYỄN TẤN DUY | Backend Architect</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <link href="https://unpkg.com/aos@next/dist/aos.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@0;100;200;300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: { extend: {
                colors: {
                    primary: "#cabeff", "on-primary": "#32009a", "primary-container": "#5800ff",
                    surface: "#131313", "on-surface": "#e5e2e1", "surface-container": "#201f1f",
                    "on-surface-variant": "#cac3da", outline: "#938ea3", background: "#131313"
                },
                fontFamily: { headline: ["Space Grotesk"], body: ["Manrope"], label: ["Space Grotesk"] },
                borderRadius: { DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem" }
            }}
        }
    </script>
    <style>
        body { font-family: "Manrope", sans-serif; background: #131313; color: #e5e2e1; overflow-x: hidden; }
        .grain { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; pointer-events: none; opacity: 0.03; background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23cabeff' fill-opacity='0.03'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
        .material-symbols-outlined { font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24; }
        .glass-panel { background: rgba(32,31,31,0.15); backdrop-filter: blur(20px); }
        html { scroll-behavior: smooth; }
        [data-aos] { pointer-events: auto; }
        .typewriter-span, .typewriter-title { overflow: hidden; border-right: 3px solid #cabeff; white-space: nowrap; animation: blink-caret 1s infinite; }
        .typewriter-title { border-right: 4px solid transparent; }
        .typewriter-cursor { display: inline-block; background: #cabeff; animation: blink 1s infinite; }
        @keyframes blink { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }
        @keyframes blink-caret { 0%, 50% { border-color: #cabeff; } 51%, 100% { border-color: transparent; } }
        .parallax-bg { will-change: transform; transition: transform 0.1s; }
        .parallax-banner { will-change: transform; transition: transform 0.8s ease-out; }
        .parallax-overlay { will-change: transform; transition: transform 0.6s ease-out; }
        
        /* Backend Matrix Evolution Styles */
        .parallax-layer { will-change: transform; transition: transform 0.1s ease-out; }
        .particles-bg { position: relative; background: radial-gradient(circle at 20% 80%, #5800ff20 0%, transparent 50%), radial-gradient(circle at 80% 20%, #00d4ff15 0%, transparent 50%), #131313; }
        .neon-glow { animation: neonPulse 4s ease-in-out infinite; }
        .wireframe-core { background: transparent; border: 2px solid transparent; background-clip: padding-box; position: relative; animation: coreRotate 20s linear infinite; }
        .wireframe-core::before, .wireframe-core::after { content: ''; position: absolute; background: linear-gradient(45deg, #cabeff, #00d4ff, #5800ff); background-size: 300% 300%; animation: gradientShift 3s ease infinite; border-radius: 50%; filter: blur(1px); opacity: 0.6; }
        .wireframe-core::before { inset: 10%; animation-direction: reverse; }
        .wireframe-core::after { inset: 25%; width: 50%; height: 50%; animation-duration: 2s; }
        
        @keyframes neonPulse { 0%, 100% { opacity: 0.3; transform: scale(1); } 50% { opacity: 0.7; transform: scale(1.05); } }
        @keyframes coreRotate { from { transform: rotateY(0deg) rotateX(0deg); } to { transform: rotateY(360deg) rotateX(180deg); } }
        @keyframes gradientShift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
        @keyframes particleFlow { 0% { transform: translateY(100vh) scale(0); opacity: 0; } 10% { opacity: 1; } 90% { opacity: 1; } 100% { transform: translateY(-100px) scale(1); opacity: 0; } }
        
        /* Glitch Effect on Title */
        .typewriter-title:hover { animation: glitch 0.3s linear infinite; }
        @keyframes glitch { 0%, 100% { transform: translate(0); } 20% { transform: translate(-2px, 2px); } 40% { transform: translate(-2px, -2px); } 60% { transform: translate(2px, 2px); } 80% { transform: translate(2px, -2px); } }
        
        /* v2.0 Tech Banner Styles */
        .tech-bg { position: relative; }
        .holographic-scan { animation: scanLine 8s linear infinite; }
        @keyframes scanLine { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        .holographic-glow { text-shadow: 0 0 20px #cabeff80, 0 0 40px #5800ff40; animation: hologramFlicker 3s ease-in-out infinite; }
        .neural-glow { background: linear-gradient(45deg, transparent 30%, #cabeff 50%, #5800ff 70%, transparent 90%); background-clip: text; -webkit-background-clip: text; background-size: 300% 300%; animation: neuralPulse 2s ease-in-out infinite; }
        .holographic-text { text-shadow: 0 0 10px rgba(202,190,255,0.3); }
        .animate-spin-slow { animation: spin 20s linear infinite; }
        .circuit-grid path { stroke-dasharray: 10; stroke-dashoffset: 0; animation: circuitFlow 4s linear infinite; }
        @keyframes hologramFlicker { 0%, 100% { opacity: 1; } 50% { opacity: 0.85; filter: hue-rotate(10deg); } }
        @keyframes neuralPulse { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
        @keyframes circuitFlow { to { stroke-dashoffset: -20; } }
        @keyframes terminal-pulse { 0%, 100% { box-shadow: 0 20px 60px rgba(88,0,255,0.4); } 50% { box-shadow: 0 20px 80px rgba(88,0,255,0.6); } }
        @keyframes code-fall { 0% { transform: translateY(100%); opacity: 0; } 10% { opacity: 1; } 90% { opacity: 1; } 100% { transform: translateY(-100%); opacity: 0; } }
        .terminal-glow { animation: terminal-pulse 2s ease-in-out infinite; }
        .code-rain { animation: code-fall 6s linear infinite; font-family: 'Courier New', monospace; font-size: 14px; color: #00ff41; text-shadow Ascending; line-height: 1.2; }
    </style>
</head>
<body class="bg-surface">
    <div class="grain"></div>

    <!-- Navbar với Mobile Menu -->
<nav class="fixed top-0 left-0 w-full z-50 bg-surface-container/95 backdrop-blur-xl transition-all duration-300 shadow-2xl" id="navbar">
        <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
            <a href="#home" class="text-2xl font-black tracking-tight text-primary font-headline uppercase hover:scale-105 transition-transform">NTD</a>
            <div class="hidden md:flex items-center space-x-6 font-headline font-bold text-sm uppercase tracking-tight">
                <a href="#home" class="nav-link py-2 px-3 rounded-lg hover:text-primary hover:bg-primary/10 transition-all duration-300" data-section="home">Home</a>
                <a href="#about" class="nav-link py-2 px-3 rounded-lg hover:text-primary hover:bg-primary/10 transition-all duration-300" data-section="about">About</a>
                <a href="#skills" class="nav-link py-2 px-3 rounded-lg hover:text-primary hover:bg-primary/10 transition-all duration-300" data-section="skills">Skills</a>
                <a href="#experience" class="nav-link py-2 px-3 rounded-lg hover:text-primary hover:bg-primary/10 transition-all duration-300" data-section="experience">Experience</a>
                <a href="#systems" class="nav-link py-2 px-3 rounded-lg hover:text-primary hover:bg-primary/10 transition-all duration-300" data-section="systems">Systems</a>
                <a href="#contact" class="nav-link py-2 px-3 rounded-lg hover:text-primary hover:bg-primary/10 transition-all duration-300" data-section="contact">Contact</a>
            </div>
            <!-- CV Download Button in Header -->
            <a href="./cv/Nguyễn_Tấn_Duy_cv (1).pdf" download="NguyenTanDuy_CV.pdf" class="hidden md:inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-2 font-headline font-bold uppercase text-sm tracking-wide hover:bg-primary-container hover:scale-105 transition-all shadow-lg ml-4" title="Download CV">
                <span class="material-symbols-outlined text-base">download</span>
                CV
            </a>
            <!-- Mobile menu button -->
            <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-primary/20 transition-all material-symbols-outlined text-2xl text-primary">menu</button>
        </div>
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="md:hidden bg-surface-container/95 backdrop-blur-xl border-t border-outline-variant/50 max-h-0 overflow-hidden transition-all duration-500">
        <div class="px-6 py-8 space-y-4">
                <a href="#home" class="nav-link block py-3 px-4 font-headline font-bold text-lg uppercase tracking-tight hover:text-primary hover:bg-primary/10 rounded-xl transition-all" data-section="home">Home</a>
                <a href="#about" class="nav-link block py-3 px-4 font-headline font-bold text-lg uppercase tracking-tight hover:text-primary hover:bg-primary/10 rounded-xl transition-all" data-section="about">About</a>
                <a href="#skills" class="nav-link block py-3 px-4 font-headline font-bold text-lg uppercase tracking-tight hover:text-primary hover:bg-primary/10 rounded-xl transition-all" data-section="skills">Skills</a>
                <a href="#experience" class="nav-link block py-3 px-4 font-headline font-bold text-lg uppercase tracking-tight hover:text-primary hover:bg-primary/10 rounded-xl transition-all" data-section="experience">Experience</a>
                <a href="#systems" class="nav-link block py-3 px-4 font-headline font-bold text-lg uppercase tracking-tight hover:text-primary hover:bg-primary/10 rounded-xl transition-all" data-section="systems">Systems</a>
                <a href="#contact" class="nav-link block py-3 px-4 font-headline font-bold text-lg uppercase tracking-tight hover:text-primary hover:bg-primary/10 rounded-xl transition-all" data-section="contact">Contact</a>
                <a href="./cv/Nguyễn_Tấn_Duy_cv (1).pdf" download="NguyenTanDuy_CV.pdf" class="nav-link block py-3 px-4 font-headline font-bold text-lg uppercase tracking-tight hover:text-primary hover:bg-primary/10 rounded-xl transition-all">Download CV</a>
            </div>
        </div>
    </nav>

    <!-- Section 1: Home -->
    <section id="home" class="min-h-screen relative pt-24 pb-20" data-aos="fade-up">
        <!-- Fullscreen Tech Banner (Edge-to-Edge) -->
        <div class="absolute inset-0 w-screen left-0 overflow-hidden">
            <!-- Neural Network + Code Rain Canvas -->
        <canvas id="tech-matrix" class="w-full h-full tech-bg"></canvas>
        
        <!-- Neural Code Rain + Developer Terminal Effect -->
        <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-black/80 to-transparent pointer-events-none">
            <div class="terminal-glow absolute bottom-8 left-1/4 w-1/2 h-32 bg-gradient-to-r from-primary/30 to-primary-container/50 rounded-lg shadow-[0_20px_60px_rgba(88,0,255,0.4)] animate-terminal-pulse"></div>
            <div class="terminal-lines absolute bottom-12 left-1/4 w-1/2 h-24 overflow-hidden">
                <div class="code-rain animate-code-fall">const backend = new Architect();<br>server.deploy(resilientSystems);<br>springBoot.optimize();<br>JWT.secureAPI();</div>
            </div>
        </div>
        
        <!-- Circuit Layers (Simplified) -->
        <svg class="absolute inset-0 w-full h-full opacity-20 circuit-grid" viewBox="0 0 100 100">
            <defs>
                <pattern id="grid" x="10" y="10" width="10" height="10" patternUnits="userSpaceOnUse">
                    <path d="M 10 0 L 0 0 0 10" fill="none" stroke="#cabeff" stroke-width="0.2"/>
                </pattern>
            </defs>
            <rect width="100" height="100" fill="url(#grid)"/>
        </svg>
                <defs>
                    <pattern id="circuit-grid" x="40" y="40" width="40" height="40" patternUnits="userSpaceOnUse">
                        <path d="M 0 20 L 40 20 M 20 0 L 20 40" stroke="#cabeff" stroke-width="0.2" opacity="0.1" />
                    </pattern>
                </defs>
                <rect width="1920" height="1080" fill="url(#circuit-grid)"/>
                <circle cx="960" cy="540" r="200" fill="none" stroke="#5800ff" stroke-width="2" stroke-dasharray="10 5" opacity="0.3">
                    <animate attributeName="stroke-dashoffset" dur="3s" values="0; 50; 0" repeatCount="indefinite"/>
                </circle>
            </svg>
            
            <!-- Holographic Gradients -->
            <div class="absolute inset-0 bg-gradient-to-r from-primary/20 via-transparent to-primary-container/30 holographic-scan"></div>
            <div class="absolute inset-0 bg-[conic-gradient(from_0deg_at_50%_50%,transparent_0deg,#00d4ff40_90deg,#5800ff80_180deg,transparent_270deg)] animate-spin-slow"></div>
        </div>

        <!-- Centered Content Overlay -->
        <div class="relative z-20 container mx-auto px-6 md:px-12 h-screen flex flex-col justify-center items-center text-center">
            <div class="mb-20" data-aos="zoom-in" data-aos-delay="200">
                <span class="font-headline text-primary font-bold tracking-[0.3em] uppercase text-sm block mb-12 typewriter-span holographic-glow" data-text="BACKEND ARCHITECT">BACKEND ARCHITECT</span>
                <h1 class="font-headline font-black text-[10vw] md:text-[8vw] tracking-tighter uppercase leading-none typewriter-title neural-glow" data-text="NGUYỄN TẤN DUY">
                    <span class="inline-block min-w-[10ch]"></span><span class="typewriter-cursor">|</span>
                </h1>
            </div>
            <p class="max-w-2xl text-xl md:text-2xl text-on-surface-variant font-body leading-relaxed px-4 mb-12 holographic-text" data-aos="fade-up" data-aos-delay="800">
                Engineering resilient distributed systems with <span class="text-primary font-bold">Java Spring Boot</span>. Seeking full-time Backend Architect roles.
            </p>
        </div>
                <!-- Layer 1: Animated Particles (CSS + Canvas) -->
                <canvas id="matrix-particles" class="w-full h-full parallax-layer particles-bg"></canvas>
                
                <!-- Layer 2: Neon Gradients -->
                <div class="absolute inset-0 bg-gradient-to-br from-primary/30 via-transparent/50 to-primary-container/40 neon-glow parallax-layer"></div>
                <div class="absolute inset-0 bg-gradient-to-tl from-[#00d4ff]/20 via-transparent to-primary/50 radial-gradient parallax-layer"></div>
                
                <!-- Layer 3: 3D Rotating Polyhedron Core -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <div id="core-polyhedron" class="w-64 h-64 md:w-96 md:h-96 wireframe-core parallax-layer"></div>
                </div>
                
                <!-- Enhanced Parallax Overlay -->
                <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent/70 to-surface-container/60 backdrop-blur-sm parallax-overlay" id="parallax-bg"></div>
            </div>
            
            <!-- Typewriter Title -->
            <div class="relative z-10">
                <span class="font-headline text-primary font-bold tracking-[0.3em] uppercase text-sm block mb-12 typewriter-span" data-text="BACKEND ARCHITECT">BACKEND ARCHITECT</span>
                <h1 class="font-headline font-black text-[12vw] md:text-[9vw] lg:text-[8vw] tracking-tighter uppercase leading-none typewriter-title" data-text="NGUYỄN TẤN DUY">
                    <span class="inline-block min-w-[10ch]"></span><span class="typewriter-cursor">|</span>
                </h1>
            </div>
            <p class="max-w-2xl mx-auto mt-16 text-xl md:text-2xl text-on-surface-variant font-body leading-relaxed relative z-10 px-4" data-aos="fade-up" data-aos-delay="800">
                Engineering resilient distributed systems with <span class="text-primary font-bold">Java Spring Boot</span>. Seeking full-time Backend Architect roles.
            </p>
        </div>
        
        <!-- Skills Grid -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-2 max-w-4xl mx-auto" data-aos="fade-up" data-aos-delay="600">
            <div class="bg-surface-container p-8 hover:bg-primary/10 transition-all group text-center"><div class="font-headline text-2xl font-bold text-primary group-hover:scale-110">JAVA</div><span class="text-xs text-on-surface-variant">Spring Boot</span></div>
            <div class="bg-surface-container p-8 hover:bg-primary/10 transition-all group text-center"><div class="font-headline text-2xl font-bold text-primary group-hover:scale-110">MYSQL</div><span class="text-xs text-on-surface-variant">Database</span></div>
            <div class="bg-surface-container p-8 hover:bg-primary/10 transition-all group text-center"><div class="font-headline text-2xl font-bold text-primary group-hover:scale-110">DOCKER</div><span class="text-xs text-on-surface-variant">DevOps</span></div>
            <div class="bg-surface-container p-8 hover:bg-primary/10 transition-all group text-center"><div class="font-headline text-2xl font-bold text-primary group-hover:scale-110">JWT</div><span class="text-xs text-on-surface-variant">Security</span></div>
            <div class="bg-surface-container p-8 hover:bg-primary/10 transition-all group text-center"><div class="font-headline text-2xl font-bold text-primary group-hover:scale-110">REST</div><span class="text-xs text-on-surface-variant">API Design</span></div>
        </div>
    </section>

    <!-- Section 2: About/Objective -->
    <section id="about" class="py-32 px-6 md:px-12 bg-surface-container-lowest max-w-6xl mx-auto" data-aos="fade-up">
        <div class="text-center mb-24" data-aos="zoom-in">
            <h2 class="font-headline text-6xl md:text-8xl font-black tracking-tight uppercase">ABOUT</h2>
            <p class="mt-8 text-xl text-on-surface-variant max-w-3xl mx-auto">Backend Architect engineering resilient distributed systems</p>
        </div>
        <div class="grid lg:grid-cols-12 gap-16 items-center">
            <div class="lg:col-span-8 space-y-8" data-aos="fade-right">
                <h3 class="font-headline text-5xl font-bold tracking-tight mb-8">The Objective</h3>
                <blockquote class="font-headline text-3xl md:text-4xl font-light text-on-surface leading-tight italic border-l-4 border-primary pl-8 py-8">
                    "Trở thành nhân viên chính thức, vận dụng kiến thức Java và Spring Boot để tạo ra giá trị."
                </blockquote>
                <p class="font-body text-xl text-on-surface-variant leading-relaxed border-l-4 border-primary pl-8 py-4 max-w-2xl">
                    Gắn bó lâu dài, không ngừng học hỏi và nỗ lực để trở thành một chuyên gia Backend vững vàng, đóng góp vào sự phát triển của hệ thống quy mô lớn.
                </p>
            </div>
            <div class="lg:col-span-4" data-aos="fade-left" data-aos-delay="200">
                <div class="glass-panel p-8 md:p-12 border-t-4 border-primary rounded-xl">
                    <h4 class="font-headline font-bold text-primary mb-6 tracking-widest uppercase text-2xl">Location</h4>
                    <p class="font-headline text-3xl font-bold mb-8">TP. Hồ Chí Minh, VN</p>
                    <h4 class="font-headline font-bold text-primary mb-6 tracking-widest uppercase text-2xl">Education</h4>
                    <div class="space-y-2">
                        <p class="font-headline text-2xl">FPT Polytechnic</p>
                        <p class="font-label text-lg text-on-surface-variant">Cao đẳng Phát triển phần mềm</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section 3: Skills -->
    <section id="skills" class="py-32 px-6 md:px-12 max-w-6xl mx-auto" data-aos="fade-up">
        <div class="text-center mb-24" data-aos="zoom-in">
            <h2 class="font-headline text-6xl md:text-8xl font-black tracking-tight uppercase">Technical Arsenal</h2>
            <p class="mt-6 text-xl text-on-surface-variant max-w-2xl mx-auto">Production-grade technologies powering enterprise systems</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-2 max-w-5xl mx-auto" data-aos="fade-up" data-aos-delay="200">
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="100">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">JAVA</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">Spring Boot</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="200">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">MYSQL</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">Database</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="300">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">DOCKER</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">DevOps</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="400">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">JWT</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">Security</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="500">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">REST</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">API Design</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="600">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">GIT</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">VCS</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="700">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">REACT</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">Frontend</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="800">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">VUE</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">Reactive</span>
            </div>
            <div class="glass-panel p-10 hover:bg-primary/10 transition-all group text-center rounded-xl" data-aos="fade-up" data-aos-delay="900">
                <span class="font-headline text-primary text-2xl block mb-3 group-hover:scale-110 transition-transform">C#</span>
                <span class="text-sm text-on-surface-variant font-label uppercase tracking-wide">.NET</span>
            </div>
