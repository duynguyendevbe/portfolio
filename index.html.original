        <div class="grid md:grid-cols-3 gap-12 max-w-4xl mx-auto mb-20" data-aos="fade-up" data-aos-delay="200">
            <div class="glass-panel p-10 rounded-xl text-center group hover:scale-105 transition-all" data-aos="fade-up">
                <span class="material-symbols-outlined text-primary text-4xl mb-4 block group-hover:scale-110">mail</span>
